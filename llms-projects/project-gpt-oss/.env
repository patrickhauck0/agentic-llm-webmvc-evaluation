# .env file - configure suas credenciais

# Porta em que o servidor Express escutará (padrão 3000)
PORT=3000

# Secret usado para assinar os tokens JWT. Substitua por um valor seguro.
JWT_SECRET=super_secret_jwt_key_sgt_2026

# URL de conexão ao Supabase PostgreSQL. Substitua <password>, <ref> e demais campos conforme sua instância.
# Formato: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:ZoJ9OpFsIH2RPYQz@db.uvatqooyrynjloojptzw.supabase.co:5432/postgres

# ---------------------------------------------------------------
